# Flask secret key
SECRET_KEY=default-secret-key

# If using Docker (which it is in production), enter 'False'
# If using Development Mode (Sqlite using plain Python), enter 'True'
# All attributes below will be ignored if using Developement Mode
DEVELOPMENT_MODE: False

# MySQL database username
MYSQL_USER=flaskuser

# MySQL database password
MYSQL_PASSWORD=flaskpassword

# MySQL Host (Use 'localhost' when in Development Mode, otherwise use 'db')
MYSQL_HOST=db

# MySQL database name
MYSQL_DATABASE=iot_project

# MySQL root password
MYSQL_ROOT_PASSWORD=root

# Flask host port (only change if there is a port conflict issue)
FLASK_HOST_PORT=5000